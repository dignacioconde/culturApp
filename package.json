{
  "name": "culturaapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "doctor:react": "npx -y react-doctor@latest . --full --offline --fail-on none",
    "doctor:react:diff": "npx -y react-doctor@latest . --diff main --offline --fail-on none",
    "context:check": "node scripts/check-agent-context.mjs",
    "context:metrics": "node scripts/check-agent-context.mjs",
    "agents:plan": "node .opencode/scripts/run-planner.mjs --draft",
    "agents:plan:draft": "node .opencode/scripts/run-planner.mjs --draft",
    "agents:plan:execute": "node .opencode/scripts/run-planner.mjs --execute",
    "agents:run": "node .opencode/scripts/run-agent.mjs",
    "agents:status": "node .opencode/scripts/run-status.mjs",
    "agents:logs": "node .opencode/scripts/run-status.mjs --logs",
    "agents:parallel": "node .opencode/scripts/run-parallel-agents.mjs",
    "agents:verify": "node .opencode/scripts/run-agent.mjs --agent verification-agent",
    "branch:cleanup": "node scripts/branch-cleanup.mjs",
    "pb:init": "node scripts/product-brain-sync.mjs init",
    "pb:status": "node scripts/product-brain-sync.mjs status",
    "pb:check": "node scripts/brain/check.mjs",
    "pb:pull": "node scripts/product-brain-sync.mjs pull",
    "pb:push": "node scripts/product-brain-sync.mjs push",
    "pb:capture": "node scripts/brain/capture.mjs",
    "pb:digest": "node scripts/brain/digest.mjs",
    "pb:index": "node scripts/brain/index.mjs",
    "pb:migrate-v2": "node scripts/brain/migrate-v2.mjs",
    "pb:orient": "node scripts/brain/orient.mjs",
    "pb:ready-check": "node scripts/brain/ready-check.mjs",
    "pb:close-check": "node scripts/brain/close-check.mjs",
    "pb:guard": "node scripts/brain/guard.mjs",
    "pb:release-check": "node scripts/brain/release-check.mjs",
    "pr:body": "node scripts/pr-body.mjs",
    "release:status": "node scripts/release-status.mjs",
    "release:sync-check": "node scripts/release-status.mjs --sync-check",
    "ship": "node scripts/ship.mjs",
    "smoke:postdeploy": "node scripts/post-deploy-smoke.mjs",
    "verify:ci": "node scripts/verify-ci.mjs",
    "verify:pr": "node scripts/verify-pr.mjs",
    "verify:brain": "node scripts/verify-brain.mjs",
    "verify:version-history": "node scripts/verify-version-history.mjs",
    "verify:skills": "node scripts/verify-skills.mjs",
    "verify:agents": "node scripts/verify-agents.mjs",
    "test:brain": "npm run pb:check -- --strict --json && npm run verify:brain",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:db": "node scripts/test-db.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "dayjs": "^1.11.20",
    "lucide-react": "^1.9.0",
    "react": "^19.2.5",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "date-fns-tz": "^3.2.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "gray-matter": "^4.0.3",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "zod": "^4.3.6"
  }
}
